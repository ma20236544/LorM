[common]
# 3. 核心控制开关（逼迫 Subconverter 把所有数据 Inline 纯文本化）
enable_rule_generator=true
overwrite_original_rules=true

# 强制将节点拉回主配置，不生成外部 proxy-provider
clash_use_provider=false

# 强制关闭所有的 rule-provider，确保生成纯 rules 列表
clash_rule_provider=false
clash_use_ruleset=false

# 开启 Clash 规则直接合并注入模式
clash_rule_base=true

quanx_rule_base=https://raw.githubusercontent.com/ma20236544/LorM/master/quanx

